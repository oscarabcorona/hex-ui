{
	"name": "@hex-ui/mcp",
	"version": "0.1.0",
	"description": "MCP server for Hex UI — AI-native component distribution",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"hex-ui-mcp": "dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@hex-ui/registry": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.12.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0"
	}
}
