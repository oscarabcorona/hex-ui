{
	"name": "@hex-ui/mcp",
	"version": "0.1.0",
	"description": "MCP server for Hex UI — AI-native component distribution. Ships 11 tools over the registry for Claude Code / Cursor / any MCP client.",
	"keywords": [
		"hex-ui",
		"mcp",
		"model-context-protocol",
		"ai-native",
		"claude-code",
		"cursor"
	],
	"license": "MIT",
	"author": "Hex UI",
	"homepage": "https://hex-ui.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oscarabcorona/hex-ui.git",
		"directory": "packages/mcp-server"
	},
	"bugs": {
		"url": "https://github.com/oscarabcorona/hex-ui/issues"
	},
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"hex-ui-mcp": "dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsup",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"test:resolver": "tsx src/tools/resolver.test.ts",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@hex-ui/registry": "workspace:^",
		"@modelcontextprotocol/sdk": "^1.12.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0"
	}
}
