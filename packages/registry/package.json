{
	"name": "@hex-core/registry",
	"version": "0.1.0",
	"description": "Zod schemas and types for the Hex UI component registry — shared between @hex-core/components, cli, and mcp.",
	"keywords": [
		"hex-ui",
		"registry",
		"zod",
		"schema",
		"component-metadata"
	],
	"license": "MIT",
	"author": "Oscar Corona <oabc4004@gmail.com>",
	"homepage": "https://hex-core.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oscarabcorona/hex-core.git",
		"directory": "packages/registry"
	},
	"bugs": {
		"url": "https://github.com/oscarabcorona/hex-core/issues"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./schema": {
			"import": "./dist/schema.js",
			"types": "./dist/schema.d.ts"
		},
		"./recipe-schema": {
			"import": "./dist/recipe-schema.js",
			"types": "./dist/recipe-schema.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist",
		"test": "vitest run"
	},
	"dependencies": {
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"tsup": "^8.3.0",
		"typescript": "^6.0.3"
	}
}
