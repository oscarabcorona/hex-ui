{
	"name": "@hex-core/cli",
	"version": "0.1.0",
	"description": "CLI for Hex UI — copy components into your project with one command.",
	"keywords": [
		"hex-ui",
		"cli",
		"component-library",
		"scaffolding",
		"shadcn-alternative"
	],
	"license": "MIT",
	"author": "Oscar Corona <oabc4004@gmail.com>",
	"homepage": "https://hex-core.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oscarabcorona/hex-core.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/oscarabcorona/hex-core/issues"
	},
	"type": "module",
	"bin": {
		"hex": "dist/index.js"
	},
	"files": [
		"dist",
		"skills",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"prebuild": "rm -rf skills && cp -R ../../skills ./skills",
		"build": "tsup",
		"dev": "tsx src/index.ts",
		"clean": "rm -rf dist skills"
	},
	"dependencies": {
		"@hex-core/registry": "workspace:^",
		"commander": "^14.0.3",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsup": "^8.3.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0"
	}
}
