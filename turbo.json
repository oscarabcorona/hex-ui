{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"build:registry": {
			"dependsOn": ["@hex-core/components#build", "@hex-core/tokens#build", "@hex-core/registry#build"],
			"outputs": ["registry/**"]
		},
		"validate": {
			"dependsOn": ["build:registry"]
		},
		"test": {
			"dependsOn": ["build"],
			"inputs": [
				"src/**",
				"test/**",
				"vitest.config.ts",
				"vitest.setup.ts",
				"package.json"
			],
			"outputs": []
		},
		"clean": {
			"cache": false
		},
		"lint": {}
	}
}
