{
	"name": "hex-ui",
	"private": true,
	"type": "module",
	"description": "AI-native component library for LLMs and humans",
	"scripts": {
		"build": "turbo build",
		"build:registry": "tsx scripts/build-registry.ts",
		"a11y-audit": "tsx scripts/a11y-audit.ts",
		"validate": "turbo validate",
		"test": "turbo test",
		"lint": "eslint . && turbo lint",
		"lint:fix": "eslint . --fix && turbo lint -- --fix",
		"format": "prettier --write .",
		"clean": "turbo clean",
		"changeset": "changeset",
		"version": "changeset version && pnpm install --lockfile-only",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.2",
		"@changesets/cli": "^2.31.0",
		"@eslint/js": "^10.0.1",
		"@hex-core/registry": "workspace:^",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jsdoc": "^62.9.0",
		"jsdom": "^29.0.2",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"tsx": "^4.19.0",
		"turbo": "^2.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=20"
	},
	"pnpm": {
		"overrides": {
			"react": "19.2.5",
			"react-dom": "19.2.5"
		}
	}
}
