{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"if": "Edit(*.{ts,tsx,js,jsx,json})|Write(*.{ts,tsx,js,jsx,json})",
						"command": "jq -r '.tool_input.file_path' | xargs npx prettier --write --ignore-unknown 2>/dev/null || true",
						"timeout": 15
					},
					{
						"type": "command",
						"if": "Edit(*.{ts,tsx})|Write(*.{ts,tsx})",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-quality.sh",
						"timeout": 30
					},
					{
						"type": "command",
						"if": "Edit(*.{ts,tsx,js,jsx})|Write(*.{ts,tsx,js,jsx})",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-security.sh",
						"timeout": 10
					},
					{
						"type": "command",
						"if": "Edit(*.{ts,tsx})|Write(*.{ts,tsx})",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-docs.sh",
						"timeout": 15
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"if": "Bash(git commit *)",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit-check.sh",
						"timeout": 15
					},
					{
						"type": "command",
						"if": "Bash(git push *)",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-check.sh",
						"timeout": 30
					}
				]
			}
		]
	},
	"permissions": {
		"allow": [
			"Bash(pnpm run *)",
			"Bash(pnpm build *)",
			"Bash(pnpm --filter *)",
			"Bash(pnpm install *)",
			"Bash(pnpm add *)",
			"Bash(git status *)",
			"Bash(git diff *)",
			"Bash(git log *)",
			"Bash(git branch *)",
			"Bash(git checkout -b *)",
			"Bash(git add *)",
			"Bash(gh pr *)",
			"Bash(gh api *)",
			"Bash(gh auth *)",
			"Bash(node *)",
			"Bash(npx prettier *)",
			"Bash(npx eslint *)",
			"Bash(ls *)",
			"WebSearch"
		]
	}
}
